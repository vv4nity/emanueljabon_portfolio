# Get a free access key at https://web3forms.com
# Enter your email (emanueljabon18@gmail.com) — they'll email you the key.
# Copy this file to .env.local and paste your key below.
NEXT_PUBLIC_WEB3FORMS_KEY=your-access-key-here

# Get a free API key at https://aistudio.google.com/apikey
# Used server-side only (never exposed to the browser) by the /api/chat
# route as the hybrid chatbot's fallback for open-ended questions.
GEMINI_API_KEY=your-gemini-api-key-here
